@page "/contact"
@model PotteryJournal.Web.Pages.ContactModel
@{
    ViewData["Title"] = "Contact";
    ViewData["ActiveNav"] = "Contact";
}

<div class="content-page">
  <h1>Contact Us</h1>
  <p>
    Have a question about a piece, a class, or an event? Send a message and we'll get back to you.
  </p>

  @if (TempData["StatusMessage"] is string statusMessage && !string.IsNullOrEmpty(statusMessage))
  {
    <p class="form-status-message">@statusMessage</p>
  }

  <form method="post" asp-page="/Contact" class="simple-form">
    <div class="simple-form-field">
      <label for="contactName">Name</label>
      <input type="text" id="contactName" asp-for="Name" maxlength="200" required>
    </div>

    <div class="simple-form-field">
      <label for="contactEmail">Email</label>
      <input type="email" id="contactEmail" asp-for="Email" maxlength="320" required>
    </div>

    <div class="simple-form-field">
      <label for="contactMessage">Message</label>
      <textarea id="contactMessage" asp-for="Message" rows="5" maxlength="1000" required></textarea>
    </div>

    <button type="submit" class="simple-form-submit">Send Message</button>
  </form>
</div>
