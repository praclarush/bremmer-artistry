@page "/"
@model PotteryJournal.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
    ViewData["ActiveNav"] = "Home";
}

<section class="hero">
  <p class="hero-eyebrow">Handmade Pottery</p>
  <h1>Placeholder headline -- introduce the current collection here.</h1>
  <p>
    Placeholder copy. This hero section introduces the studio and its current body of work.
    Replace with real copy and a photo once available.
  </p>
  <a class="btn" href="/gallery">View Gallery</a>
</section>

<div class="section-heading">
  <h2>Upcoming Events</h2>
  <a href="/events">See all events &rarr;</a>
</div>

@if (Model.UpcomingEvents.Count == 0)
{
  <p class="empty-state">No events scheduled right now -- check back soon.</p>
}
else
{
  <div class="event-cards">
    @foreach (PotteryJournal.Infrastructure.Models.EventModel evt in Model.UpcomingEvents)
    {
      <article class="event-card">
        @if (!string.IsNullOrEmpty(evt.ImageFileName))
        {
          <div class="event-card-photo">
            <img src="/uploads/events/@evt.ImageFileName" alt="@evt.Title" loading="lazy">
          </div>
        }
        <div class="event-card-body">
          <span class="event-date">@evt.StartDateTime.ToString("MMM d, yyyy")</span>
          <h3>@evt.Title</h3>
          @if (!string.IsNullOrEmpty(evt.VenueName))
          {
            <p class="event-venue">@evt.VenueName</p>
          }
        </div>
      </article>
    }
  </div>
}
