@page "/"
@model PotteryJournal.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
    ViewData["ActiveNav"] = "Home";
}

@section Styles {
  <link rel="stylesheet" href="~/css/events.css" asp-append-version="true">
}

<div class="home-intro">
  <section class="hero">
    <p class="hero-eyebrow">Handmade Pottery</p>
    <h1>Capturing a sense of flow and intensity within still forms.</h1>
    <p>
      Bremmer Artistry is a ceramic studio creating handmade pottery, from functional pieces like
      teapots, cups, and bowls to artistic forms. The work is defined by ongoing experiments in
      shape, surface, and firing, often drawing inspiration from dynamic natural patterns like
      lightning and rivers.
    </p>
    <div class="hero-actions">
      <a class="btn" href="/events">See Upcoming Events</a>
      <a class="hero-secondary-link" href="/gallery">View Gallery &rarr;</a>
    </div>
  </section>

  @if (Model.FeaturedCollection is not null)
  {
    <section class="featured-collection" data-featured-collection aria-label="Featured collection: @Model.FeaturedCollection.CollectionName">
      <p class="hero-eyebrow">Featured Collection</p>
      <h2>@Model.FeaturedCollection.CollectionName</h2>
      <div class="featured-collection-stage">
        @for (int i = 0; i < Model.FeaturedCollection.Pieces.Count; i++)
        {
          PotteryJournal.Infrastructure.Models.FeaturedCollectionPieceModel piece = Model.FeaturedCollection.Pieces[i];
          <figure class="featured-collection-slide@(i == 0 ? " is-active" : string.Empty)" data-featured-slide>
            <img src="/uploads/pieces/@piece.ImageFileName" alt="@piece.Title" loading="eager">
          </figure>
        }
      </div>
      <a class="hero-secondary-link" href="/gallery#category/@Uri.EscapeDataString(Model.FeaturedCollection.CollectionName)">See the full @Model.FeaturedCollection.CollectionName &rarr;</a>
    </section>
  }
</div>

<div class="section-heading">
  <h2>Upcoming Events</h2>
  <a href="/events">See all events &rarr;</a>
</div>

@if (Model.UpcomingEvents.Count == 0)
{
  <div class="home-events-empty">
    <p class="empty-state">No events scheduled right now -- check back soon.</p>
    <a class="hero-secondary-link" href="/pottery-journal">Browse the Pottery Journal &rarr;</a>
  </div>
}
else
{
  <div class="event-cards">
    @foreach (PotteryJournal.Infrastructure.Models.EventModel evt in Model.UpcomingEvents)
    {
      <a class="event-card" href="/events#event-@evt.Id">
        @if (!string.IsNullOrEmpty(evt.ImageFileName))
        {
          <div class="event-card-photo">
            <img src="/uploads/events/@evt.ImageFileName" alt="@evt.Title" loading="lazy">
          </div>
        }
        <div class="event-card-body">
          <span class="event-date">@evt.StartDateTime.ToString("MMM d, yyyy")</span>
          <h3>@evt.Title</h3>
          @if (!string.IsNullOrEmpty(evt.VenueName))
          {
            <p class="event-venue">@evt.VenueName</p>
          }
        </div>
      </a>
    }
  </div>
}

@section Scripts {
  <script src="~/js/featured-collection.js" asp-append-version="true"></script>
}
