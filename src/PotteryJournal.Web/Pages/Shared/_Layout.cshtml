@{
    string activeNav = ViewData["ActiveNav"] as string ?? string.Empty;
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>@ViewData["Title"] - Bremmer Artistry</title>
<meta name="description" content="Handmade pottery, the Pottery Journal catalog, and upcoming shows and events.">
<link rel="icon" href="~/favicon.svg" type="image/svg+xml">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=IBM+Plex+Mono:wght@400;500;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true">
@await RenderSectionAsync("Styles", required: false)
</head>
<body class="site-body">

<header class="site-nav">
  <a class="wordmark" href="/">Bremmer <span>Artistry</span></a>
  <ul class="nav-links">
    <li><a href="/" aria-current="@(activeNav == "Home" ? "page" : null)">Home</a></li>
    <li><a href="/gallery" aria-current="@(activeNav == "Gallery" ? "page" : null)">Gallery</a></li>
    <li><a href="/pottery-journal" aria-current="@(activeNav == "PotteryJournal" ? "page" : null)">Pottery Journal</a></li>
    <li><a href="/events" aria-current="@(activeNav == "Events" ? "page" : null)">Events</a></li>
    <li><a href="/faq" aria-current="@(activeNav == "Faq" ? "page" : null)">FAQ</a></li>
    <li><a href="/about" aria-current="@(activeNav == "About" ? "page" : null)">About</a></li>
  </ul>
</header>

<main class="site-main">
  @RenderBody()
</main>

<footer class="site-footer">
  <span>&copy; @DateTime.UtcNow.Year Bremmer Artistry</span>
  <span>
    <a href="mailto:info@bremmer-artistry.art">info@bremmer-artistry.art</a>
    &middot;
    <a href="https://www.instagram.com/bremmerArtistry" target="_blank" rel="noopener">@@bremmerArtistry</a>
  </span>
</footer>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
