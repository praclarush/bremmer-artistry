@page "/gallery"
@{
    ViewData["Title"] = "Gallery";
    ViewData["ActiveNav"] = "Gallery";
}

@section Styles {
  <link rel="stylesheet" href="~/css/gallery.css" asp-append-version="true">
  <link rel="stylesheet" href="~/css/pottery-journal.css" asp-append-version="true">
}

<div class="section-heading">
  <h2>Gallery</h2>
</div>
<p id="galleryIntro" class="gallery-intro">
  A showcase of finished work, organized by category. For the full record behind every piece --
  glazes, clay, notes -- see the <a href="/pottery-journal">Pottery Journal</a>.
</p>

<div id="categoriesView" class="category-grid"></div>
<p id="categoriesEmpty" class="empty-state hidden">No finished pieces have been added to the Gallery yet.</p>

<section id="categoryView" class="gallery-category-view hidden">
  <button id="categoryBackBtn" class="back-btn">&larr; back to categories</button>
  <h2 id="categoryTitle" class="gallery-category-title"></h2>
  <div id="categoryGrid" class="gallery" aria-live="polite"></div>
</section>

<div id="lightbox" class="lightbox hidden" role="dialog" aria-modal="true" aria-label="Photo viewer">
  <button id="lightboxClose" class="lightbox-close" aria-label="Close">&times;</button>
  <button id="lightboxPrev" class="lightbox-arrow prev" aria-label="Previous photo">&lsaquo;</button>
  <button id="lightboxNext" class="lightbox-arrow next" aria-label="Next photo">&rsaquo;</button>
  <figure class="lightbox-figure">
    <img id="lightboxImage" alt="">
    <figcaption id="lightboxCaption"></figcaption>
  </figure>
</div>

@section Scripts {
  <script src="~/js/gallery.js" asp-append-version="true"></script>
}
