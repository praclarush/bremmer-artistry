@page "/classes"
@model PotteryJournal.Web.Pages.ClassesModel
@{
    ViewData["Title"] = "Classes";
    ViewData["ActiveNav"] = "Classes";
}

@section Styles {
  <link rel="stylesheet" href="~/css/classes.css" asp-append-version="true">
}

<div class="section-heading">
  <h2>Classes</h2>
</div>

<div class="classes-intro">
  <p>
    Pick a Wheel Throw or Hand-Building slot below and send a request. Every booking is
    <strong>tentative</strong> until we confirm it -- you'll get an email once it's approved.
  </p>
</div>

@if (TempData["StatusMessage"] is string statusMessage && !string.IsNullOrEmpty(statusMessage))
{
  <p class="form-status-message">@statusMessage</p>
}

<div id="classSlots" class="class-slot-groups"></div>
<p id="classesEmptyState" class="empty-state hidden">No class slots are available to book right now -- check back soon.</p>

<form method="post" asp-page-handler="Book" id="bookingForm" class="simple-form booking-form hidden">
  <h3>Complete your booking</h3>
  <p id="bookingSummary" class="booking-summary"></p>

  <input type="hidden" name="Booking.ClassTypeId" id="bookingClassTypeId">
  <input type="hidden" name="Booking.StartDateTime" id="bookingStartDateTime">

  <div class="simple-form-field">
    <label for="bookingName">Name</label>
    <input type="text" id="bookingName" name="Booking.CustomerName" required>
  </div>

  <div class="simple-form-field">
    <label for="bookingEmail">Email</label>
    <input type="email" id="bookingEmail" name="Booking.CustomerEmail" required>
  </div>

  <div class="simple-form-field">
    <label for="bookingPhone">Phone (optional)</label>
    <input type="tel" id="bookingPhone" name="Booking.CustomerPhone">
  </div>

  <div class="simple-form-field">
    <label for="bookingPartySize">Party size</label>
    <input type="number" id="bookingPartySize" name="Booking.PartySize" min="1" value="1" required>
  </div>

  <div class="simple-form-field">
    <label for="bookingMessage">Message (optional)</label>
    <textarea id="bookingMessage" name="Booking.Message" rows="3"></textarea>
  </div>

  <button type="submit" class="simple-form-submit">Request Booking</button>
</form>

@section Scripts {
  <script src="~/js/classes.js" asp-append-version="true"></script>
}
