@page "/admin/login"
@model PotteryJournal.Web.Pages.Admin.LoginModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "/Pages/Admin/_AuthLayout.cshtml";
}

<div class="row justify-content-center">
  <div class="col-md-5 py-5">
    <h1 class="h3 mb-4 text-center">Admin Sign In</h1>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
      <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <form method="post">
      <input type="hidden" asp-for="ReturnUrl">
      <div class="mb-3">
        <label class="form-label" for="email">Email</label>
        <input type="email" class="form-control" id="email" asp-for="Email" required autofocus>
      </div>
      <div class="mb-3">
        <label class="form-label" for="password">Password</label>
        <input type="password" class="form-control" id="password" asp-for="Password" required>
      </div>
      <button type="submit" class="btn btn-primary w-100">Sign In</button>
    </form>
  </div>
</div>
