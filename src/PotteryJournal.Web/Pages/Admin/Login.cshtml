@page "/admin/login"
@model PotteryJournal.Web.Pages.Admin.LoginModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
  <div class="col-md-5 text-center py-5">
    <h1 class="h3 mb-4">Admin Sign In</h1>
    <p class="text-muted mb-4">Sign in with an allow-listed Google account to manage the Pottery Journal and Events.</p>
    <form method="post" asp-page-handler="Challenge">
      <button type="submit" class="btn btn-primary">Sign in with Google</button>
    </form>
  </div>
</div>
