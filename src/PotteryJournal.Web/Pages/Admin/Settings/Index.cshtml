@page "/admin/settings"
@model PotteryJournal.Web.Pages.Admin.Settings.IndexModel
@{
    ViewData["Title"] = "Settings";
}

<h1 class="h3 mb-4">Settings</h1>
<p class="text-muted">
  Controls how class bookings and Contact Us messages reach you.
</p>

<div class="card" style="max-width: 32rem;">
  <div class="card-body">
    <form method="post">
      <div class="mb-3">
        <label class="form-label" for="notificationRecipientEmail">Notification recipient email</label>
        <input type="email" class="form-control" id="notificationRecipientEmail"
               asp-for="Settings.NotificationRecipientEmail" required>
        <div class="form-text">
          Class booking requests and Contact Us submissions are both sent here.
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label" for="minimumBookingLeadDays">Minimum booking lead time (days)</label>
        <input type="number" class="form-control" id="minimumBookingLeadDays"
               asp-for="Settings.MinimumBookingLeadDays" min="0" style="max-width: 8rem;" required>
        <div class="form-text">
          A class can't be booked less than this many days before it starts.
        </div>
      </div>

      <button type="submit" class="btn btn-primary">Save</button>
    </form>
  </div>
</div>
