@page "/admin/pieces/edit/{id:guid?}"
@model PotteryJournal.Web.Pages.Admin.Pieces.EditModel

@{
    ViewData["Title"] = Model.Id.HasValue ? "Edit Piece" : "New Piece";

    // asp-route-id with a null Guid? adds an explicit null route value instead of omitting the
    // "id" segment, which breaks Form Tag Helper URL generation for the New Piece page (the form
    // silently renders action="" -- see CLAUDE.md / Admin/Events/Edit.cshtml for the same bug).
    // asp-all-route-data with a dictionary that only contains "id" when Model.Id has a value
    // sidesteps that while keeping the Form Tag Helper active for its antiforgery token injection.
    Dictionary<string, string> saveRouteValues = new Dictionary<string, string>();
    if (Model.Id.HasValue)
    {
        saveRouteValues["id"] = Model.Id.Value.ToString();
    }
}

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 m-0">
    @(Model.Id.HasValue ? $"Edit Piece #{Model.PieceNumber:000}" : "New Piece")
  </h1>
  <a class="btn btn-outline-secondary btn-sm" href="/admin/reference-data">Manage Clays / Glazes / Categories</a>
</div>

<form method="post" asp-page-handler="Save" asp-all-route-data="saveRouteValues">
  <div class="row mb-3">
    <div class="col-sm-8">
      <label class="form-label" for="title">Title</label>
      <input type="text" class="form-control" id="title" asp-for="Piece.Title" required>
    </div>
    <div class="col-sm-4">
      <label class="form-label" for="category">Category</label>
      <select class="form-select" id="category" asp-for="Piece.CategoryId">
        <option value="">&mdash; None &mdash;</option>
        @foreach (PotteryJournal.Infrastructure.Models.LookupItemModel category in Model.Categories)
        {
          <option value="@category.Id">@category.Name</option>
        }
      </select>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-12">
      <div class="form-check">
        <input type="checkbox" class="form-check-input" id="showInGallery" asp-for="Piece.ShowInGallery">
        <label class="form-check-label" for="showInGallery">Show in Gallery</label>
        <div class="form-text">
          The Pottery Journal and Gallery are independent -- every piece is logged here for
          record-keeping, but only pieces checked here appear as finished work on the public
          Gallery page. Set a Category above to group it there; if you leave Category blank but
          set a Collection below, the piece is grouped under the Collection name instead.
        </div>
      </div>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-sm-4">
      <label class="form-label" for="collection">Collection</label>
      <select class="form-select" id="collection" asp-for="Piece.CollectionId">
        <option value="">&mdash; None &mdash;</option>
        @foreach (PotteryJournal.Infrastructure.Models.CollectionModel collection in Model.Collections)
        {
          <option value="@collection.Id">@collection.Name</option>
        }
      </select>
      <div class="form-text">
        Groups pieces for the homepage rotating display. If a piece has no Category, it also
        becomes the piece's Gallery grouping in place of a Category.
      </div>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-sm-4">
      <label class="form-label" for="clayBody">Clay</label>
      <select class="form-select" id="clayBody" asp-for="Piece.ClayBodyId">
        <option value="">&mdash; Unspecified &mdash;</option>
        @foreach (PotteryJournal.Infrastructure.Models.LookupItemModel clayBody in Model.ClayBodies)
        {
          <option value="@clayBody.Id">@clayBody.Name</option>
        }
      </select>
    </div>
    <div class="col-sm-4">
      <label class="form-label" for="startedDate">Started</label>
      <input type="date" class="form-control" id="startedDate" asp-for="Piece.StartedDate" required>
    </div>
    <div class="col-sm-4">
      <label class="form-label" for="finishedDate">Finished (optional)</label>
      <input type="date" class="form-control" id="finishedDate" asp-for="Piece.FinishedDate">
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-sm-6">
      <label class="form-label" for="sizeText">Size</label>
      <input type="text" class="form-control" id="sizeText" asp-for="Piece.SizeText" placeholder="e.g. 6&quot; x 4&quot;" required>
    </div>
    <div class="col-sm-6">
      <label class="form-label" for="weightText">Weight</label>
      <input type="text" class="form-control" id="weightText" asp-for="Piece.WeightText" required>
    </div>
  </div>

  <div class="mb-3">
    <label class="form-label" for="glazeSummary">Glaze summary</label>
    <input type="text" class="form-control" id="glazeSummary" asp-for="Piece.GlazeSummary" required>
  </div>

  <div class="mb-3">
    <label class="form-label" for="attachmentsText">Attachments (optional)</label>
    <input type="text" class="form-control" id="attachmentsText" asp-for="Piece.AttachmentsText">
  </div>

  <fieldset class="mb-4">
    <legend class="h5">Notes</legend>
    <div id="notesRows">
      @for (int i = 0; i < Model.Piece.Notes.Count; i++)
      {
        <div class="admin-repeatable-row">
          <div class="row g-2">
            <div class="col-sm-4">
              <input type="text" class="form-control" name="Piece.Notes[@i].Title" value="@Model.Piece.Notes[i].Title" placeholder="Title (optional)">
            </div>
            <div class="col-sm-7">
              <input type="text" class="form-control" name="Piece.Notes[@i].NoteText" value="@Model.Piece.Notes[i].NoteText" placeholder="Note text">
            </div>
            <div class="col-sm-1">
              <button type="button" class="btn btn-outline-danger btn-sm" data-remove-row>&times;</button>
            </div>
          </div>
        </div>
      }
    </div>
    <template id="notesRowsTemplate">
      <div class="admin-repeatable-row">
        <div class="row g-2">
          <div class="col-sm-4">
            <input type="text" class="form-control" name="Piece.Notes[__index__].Title" placeholder="Title (optional)">
          </div>
          <div class="col-sm-7">
            <input type="text" class="form-control" name="Piece.Notes[__index__].NoteText" placeholder="Note text">
          </div>
          <div class="col-sm-1">
            <button type="button" class="btn btn-outline-danger btn-sm" data-remove-row>&times;</button>
          </div>
        </div>
      </div>
    </template>
    <button type="button" class="btn btn-outline-secondary btn-sm" data-add-row="notesRows">+ Add Note</button>
  </fieldset>

  <fieldset class="mb-4">
    <legend class="h5">Glaze Applications</legend>
    <div id="glazeRows">
      @for (int i = 0; i < Model.Piece.GlazeApplications.Count; i++)
      {
        <div class="admin-repeatable-row">
          <div class="row g-2">
            <div class="col-sm-3">
              <input type="text" class="form-control" name="Piece.GlazeApplications[@i].Location" value="@Model.Piece.GlazeApplications[i].Location" placeholder="Location">
            </div>
            <div class="col-sm-5">
              <select class="form-select" name="Piece.GlazeApplications[@i].GlazeId">
                <option value="">&mdash; Choose a glaze &mdash;</option>
                @foreach (PotteryJournal.Infrastructure.Models.LookupItemModel glaze in Model.Glazes)
                {
                  <option value="@glaze.Id" selected="@(Model.Piece.GlazeApplications[i].GlazeId == glaze.Id)">@glaze.Name</option>
                }
              </select>
            </div>
            <div class="col-sm-3">
              <input type="number" min="1" class="form-control" name="Piece.GlazeApplications[@i].Coats" value="@Model.Piece.GlazeApplications[i].Coats" placeholder="Coats">
            </div>
            <div class="col-sm-1">
              <button type="button" class="btn btn-outline-danger btn-sm" data-remove-row>&times;</button>
            </div>
          </div>
        </div>
      }
    </div>
    <template id="glazeRowsTemplate">
      <div class="admin-repeatable-row">
        <div class="row g-2">
          <div class="col-sm-3">
            <input type="text" class="form-control" name="Piece.GlazeApplications[__index__].Location" placeholder="Location">
          </div>
          <div class="col-sm-5">
            <select class="form-select" name="Piece.GlazeApplications[__index__].GlazeId">
              <option value="">&mdash; Choose a glaze &mdash;</option>
              @foreach (PotteryJournal.Infrastructure.Models.LookupItemModel glaze in Model.Glazes)
              {
                <option value="@glaze.Id">@glaze.Name</option>
              }
            </select>
          </div>
          <div class="col-sm-3">
            <input type="number" min="1" class="form-control" name="Piece.GlazeApplications[__index__].Coats" placeholder="Coats">
          </div>
          <div class="col-sm-1">
            <button type="button" class="btn btn-outline-danger btn-sm" data-remove-row>&times;</button>
          </div>
        </div>
      </div>
    </template>
    <button type="button" class="btn btn-outline-secondary btn-sm" data-add-row="glazeRows">+ Add Glaze Application</button>
  </fieldset>

  <button type="submit" class="btn btn-primary">Save</button>
  <a class="btn btn-link" href="/admin/pieces">Cancel</a>
</form>

@if (Model.Id.HasValue)
{
  <hr class="my-4">
  <h2 class="h5 mb-3">Photos</h2>

  <div class="row g-3 mb-3">
    @foreach (PotteryJournal.Infrastructure.Models.PieceImageModel image in Model.Images)
    {
      <div class="col-auto text-center">
        <img class="admin-thumb d-block mb-1" src="/uploads/pieces/@image.FileName" alt="Piece photo">
        <form method="post" asp-page-handler="RemoveImage" asp-route-id="@Model.Id" asp-route-imageId="@image.Id"
              onsubmit="return confirm('Remove this photo?');">
          <button type="submit" class="btn btn-outline-danger btn-sm">Remove</button>
        </form>
      </div>
    }
  </div>

  <form method="post" asp-page-handler="UploadImage" asp-route-id="@Model.Id" enctype="multipart/form-data" class="d-flex gap-2 align-items-end">
    <div>
      <label class="form-label" for="image">Upload photo</label>
      <input type="file" class="form-control" id="image" name="image" accept="image/*" required>
    </div>
    <button type="submit" class="btn btn-secondary">Upload</button>
  </form>
}
else
{
  <p class="text-muted mt-4">Save the piece first to add photos.</p>
}
