@page "/admin/pieces"
@model PotteryJournal.Web.Pages.Admin.Pieces.IndexModel
@{
    ViewData["Title"] = "Pieces";

    (string Column, string Label)[] columns =
    {
        ("number", "#"),
        ("title", "Title"),
        ("clay", "Clay"),
        ("category", "Category"),
        ("gallery", "Gallery"),
        ("started", "Started"),
    };

    string currentSort = string.IsNullOrEmpty(Model.Sort) ? "number" : Model.Sort;

    string SortUrl(string column)
    {
        bool nextDesc = currentSort == column && !Model.Desc;
        return Url.Page("Index", new { sort = column, desc = nextDesc, page = 1 })!;
    }

    string SortIndicator(string column)
    {
        if (currentSort != column)
        {
            return string.Empty;
        }
        return Model.Desc ? " ▾" : " ▴";
    }
}

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 m-0">Pottery Journal Pieces</h1>
  <a class="btn btn-primary" href="/admin/pieces/edit">New Piece</a>
</div>

<table class="table table-striped">
  <thead>
    <tr>
      @foreach ((string column, string label) in columns)
      {
        <th><a class="text-decoration-none" href="@SortUrl(column)">@label@SortIndicator(column)</a></th>
      }
      <th></th>
    </tr>
  </thead>
  <tbody>
    @foreach (PotteryJournal.Infrastructure.Models.PieceSummaryModel piece in Model.Pieces)
    {
      <tr>
        <td>#@piece.PieceNumber.ToString("000")</td>
        <td>@piece.Title</td>
        <td>@piece.Clay</td>
        <td>@piece.Category</td>
        <td>
          @if (piece.ShowInGallery)
          {
            <span class="badge text-bg-success">Shown</span>
          }
        </td>
        <td>@piece.StartedDate.ToString("yyyy-MM-dd")</td>
        <td class="text-end">
          <a class="btn btn-outline-secondary btn-sm" href="/admin/pieces/edit/@piece.Id">Edit</a>
          <form method="post" asp-page-handler="Delete" asp-route-id="@piece.Id" class="d-inline"
                onsubmit="return confirm('Delete &quot;@piece.Title&quot;?');">
            <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
          </form>
        </td>
      </tr>
    }
    @if (Model.Pieces.Count == 0)
    {
      <tr>
        <td colspan="7" class="text-muted">No pieces yet.</td>
      </tr>
    }
  </tbody>
</table>

@if (Model.TotalPages > 1)
{
  <nav aria-label="Pieces pagination">
    <ul class="pagination">
      <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
        <a class="page-link" href="@Url.Page("Index", new { sort = Model.Sort, desc = Model.Desc, page = Model.PageNumber - 1 })">Previous</a>
      </li>
      @for (int p = 1; p <= Model.TotalPages; p++)
      {
        <li class="page-item @(p == Model.PageNumber ? "active" : "")">
          <a class="page-link" href="@Url.Page("Index", new { sort = Model.Sort, desc = Model.Desc, page = p })">@p</a>
        </li>
      }
      <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
        <a class="page-link" href="@Url.Page("Index", new { sort = Model.Sort, desc = Model.Desc, page = Model.PageNumber + 1 })">Next</a>
      </li>
    </ul>
  </nav>
  <p class="text-muted small">@Model.TotalRecords pieces total.</p>
}
