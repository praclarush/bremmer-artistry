@page "/admin/classes/availability/create"
@model PotteryJournal.Web.Pages.Admin.Classes.Availability.CreateModel
@{
    ViewData["Title"] = "New Availability";
}

<h1 class="h3 mb-4">New Availability</h1>

<form method="post" asp-page-handler="Save" style="max-width: 40rem;">
  <div class="mb-3">
    <label class="form-label" for="classTypeId">Class type</label>
    <select class="form-select" id="classTypeId" asp-for="Rule.ClassTypeId" required>
      <option value="">Select a class type...</option>
      @foreach (PotteryJournal.Infrastructure.Models.ClassTypeModel classType in Model.ClassTypes)
      {
        <option value="@classType.Id">@classType.Name (max @classType.MaxCapacity)</option>
      }
    </select>
  </div>

  <div class="mb-3">
    <label class="form-label" for="startDateTime">Starts</label>
    <input type="datetime-local" class="form-control" id="startDateTime" name="Rule.StartDateTime"
           value="@Model.Rule.StartDateTime.ToString("yyyy-MM-ddTHH:mm")" required>
    <div class="form-text">Classes are always fixed 2-hour segments.</div>
  </div>

  <div class="row mb-3">
    <div class="col-sm-4">
      <label class="form-label" for="recurrenceFrequency">Repeats</label>
      <select class="form-select" id="recurrenceFrequency" asp-for="Rule.RecurrenceFrequency" data-recurrence-toggle="recurrenceFields">
        <option value="None">Does not repeat</option>
        <option value="Daily">Daily</option>
        <option value="Weekly">Weekly</option>
        <option value="Monthly">Monthly</option>
      </select>
    </div>
    <div id="recurrenceFields" class="col-sm-8 row g-3">
      <div class="col-sm-6">
        <label class="form-label" for="recurrenceInterval">Every</label>
        <input type="number" class="form-control" id="recurrenceInterval" asp-for="Rule.RecurrenceInterval" min="1">
        <div class="form-text">E.g. 2 with Weekly means every 2 weeks.</div>
      </div>
      <div class="col-sm-6">
        <label class="form-label" for="recurrenceEndDate">Repeat until (optional)</label>
        <input type="date" class="form-control" id="recurrenceEndDate" name="Rule.RecurrenceEndDate"
               value="@(Model.Rule.RecurrenceEndDate?.ToString("yyyy-MM-dd"))">
      </div>
    </div>
  </div>

  <button type="submit" class="btn btn-primary">Save</button>
  <a class="btn btn-link" href="/admin/classes/availability">Cancel</a>
</form>
