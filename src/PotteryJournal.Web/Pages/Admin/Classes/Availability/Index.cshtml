@page "/admin/classes/availability"
@model PotteryJournal.Web.Pages.Admin.Classes.Availability.IndexModel
@{
    ViewData["Title"] = "Class Availability";
}

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 m-0">Class Availability</h1>
  <a class="btn btn-primary" href="/admin/classes/availability/create">New Availability</a>
</div>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Class Type</th>
      <th>Starts</th>
      <th>Repeats</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    @foreach (PotteryJournal.Infrastructure.Models.ClassAvailabilityModel rule in Model.Rules)
    {
      <tr>
        <td>@rule.ClassTypeName</td>
        <td>@rule.StartDateTime.ToString("yyyy-MM-dd HH:mm")</td>
        <td>@PotteryJournal.Web.Pages.Admin.Classes.Availability.IndexModel.FormatRecurrence(rule)</td>
        <td class="text-end">
          <form method="post" asp-page-handler="Delete" asp-route-id="@rule.Id" class="d-inline"
                onsubmit="return confirm('Delete this availability rule?');">
            <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
          </form>
        </td>
      </tr>
    }
    @if (Model.Rules.Count == 0)
    {
      <tr>
        <td colspan="4" class="text-muted">None yet.</td>
      </tr>
    }
  </tbody>
</table>
