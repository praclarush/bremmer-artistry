@page "/admin/access-denied"
@model PotteryJournal.Web.Pages.Admin.AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
  <div class="col-md-6 text-center py-5">
    <h1 class="h3 mb-3">Access Denied</h1>
    <p class="text-muted">That Google account is not on the admin allow-list.</p>
    <a class="btn btn-secondary" href="/admin/login">Try a different account</a>
  </div>
</div>
