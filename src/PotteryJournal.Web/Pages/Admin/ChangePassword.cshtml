@page "/admin/change-password"
@model PotteryJournal.Web.Pages.Admin.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<h1 class="h3 mb-4">Change Password</h1>

<div class="row">
  <div class="col-md-5">
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
      <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <form method="post">
      <div class="mb-3">
        <label class="form-label" for="currentPassword">Current password</label>
        <input type="password" class="form-control" id="currentPassword" asp-for="CurrentPassword" required>
      </div>
      <div class="mb-3">
        <label class="form-label" for="newPassword">New password</label>
        <input type="password" class="form-control" id="newPassword" asp-for="NewPassword" required>
      </div>
      <div class="mb-3">
        <label class="form-label" for="confirmNewPassword">Confirm new password</label>
        <input type="password" class="form-control" id="confirmNewPassword" asp-for="ConfirmNewPassword" required>
      </div>
      <button type="submit" class="btn btn-primary">Update Password</button>
    </form>
  </div>
</div>
