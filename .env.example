# Copy to .env and fill in real values. .env is gitignored -- never commit real secrets.

POSTGRES_PASSWORD=change-me

# Seeded into AllowedAdmins on first startup if the table is empty -- this is the only account
# that can sign in until it adds more from /admin/allowed-admins.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# SMTP settings for outbound email (class booking notifications/confirmations, Contact Us
# submissions). Left blank, email sends will fail (caught and reported, not thrown) -- fine for
# local dev if you're not testing those flows.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=Bremmer Artistry
SMTP_USE_STARTTLS=true
